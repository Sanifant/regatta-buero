{
    "version": "0.2.0",
    "compounds": [
        {
            "name": "Run Regattabuero",
            "presentation": {
				"group": "maingroup",
				"order": 1
			},
            "configurations": [
                "BackEnd"
            ]
        }
    ],
    "configurations": [
        {
            "name": "BackEnd",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build backend",
            "program": "${workspaceFolder}/src/LRV.Regatta.Buero/bin/Debug/net8.0/LRV.Regatta.Buero.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/LRV.Regatta.Buero",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}