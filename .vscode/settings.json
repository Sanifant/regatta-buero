{
    "cSpell.customDictionaries": {
        "custom-dictionary-workspace": {
            "name": "custom-dictionary-workspace",
            "path": "${workspaceFolder:regatta-buero}/.cspell/custom-dictionary-workspace.txt",
            "addWords": true,
            "scope": "workspace"
        }
    },
    "cSpell.languageSettings": [
        {"languageId":"csharp", "locale": "en", "dictionaries": ["wordsEn"]},
        {"languageId":"markdown", "locale": "de", "dictionaries": ["wordsDe"]}
    ],
    "cSpell.language": "en,de-de"
}