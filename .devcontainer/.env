DB_NAME=app
DB_HOST=mysqldb
DB_USER=app_user
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=example

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API-Schlüssel & JWT (Platzhalter only; echte Werte über lokale/Devcontainer-Secrets setzen)
API_KEY=CHANGE_ME_API_KEY
JWT_KEY=CHANGE_ME_JWT_SIGNING_KEY
JWT_ISSUER=RegattaApi
JWT_AUDIENCE=RegattaApiUser
JWT_EXPIRES_MINUTES=60